# Environment: local, uat, production
ENVIRONMENT=local

# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# WhatsApp Cloud API (optional -- leave blank to disable WhatsApp)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Verify API base URL
VERIFY_API_URL=https://api-verify.straker.ai

# Order API base URL (ECFMG certified translations)
ORDER_BASE_URL=https://uat-order.strakertranslations.com

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Webhook / Server
# The public URL where this server is reachable (e.g. ngrok URL)
WEBHOOK_BASE_URL=
# Optional: secret token for Telegram webhook validation
WEBHOOK_SECRET=
# Server port (default: 8443)
PORT=8443

# Verify Database (for callback notifications)
# Required for storing notification identifiers per project and receiving
# completion notifications from the Verify consumer.
VERIFY_DB_HOST=
VERIFY_DB_PORT=3306
VERIFY_DB_USER=
VERIFY_DB_PASSWORD=
VERIFY_DB_NAME=verify

# Redis (optional, for session persistence - Phase 2)
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=
